{
  "name": "cat-pet",
  "version": "1.0.0",
  "description": "A desktop cat pet that follows your mouse cursor",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "devDependencies": {
    "electron": "33.0.0",
    "electron-builder": "^25.1.8",
    "rcedit": "^5.0.1"
  },
  "build": {
    "appId": "com.xiaopixiu.catpet",
    "productName": "小皮休",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "resources/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "resources/icon256.png",
      "artifactName": "小皮休."
    }
  }
}
